{
  "groups": [
    {
      "name": "studio.features.ai",
      "description": "AI feature wiring properties."
    },
    {
      "name": "studio.ai.routing",
      "description": "AI default provider routing properties."
    },
    {
      "name": "studio.ai.providers",
      "description": "AI provider registry properties."
    },
    {
      "name": "studio.ai.rag",
      "description": "AI RAG runtime properties."
    }
  ],
  "properties": [
    {
      "name": "studio.features.ai.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": false,
      "description": "Enable the AI feature."
    },
    {
      "name": "studio.ai.routing.default-chat-provider",
      "type": "java.lang.String",
      "description": "Default chat provider id."
    },
    {
      "name": "studio.ai.routing.default-embedding-provider",
      "type": "java.lang.String",
      "description": "Default embedding provider id."
    },
    {
      "name": "studio.ai.providers.*.type",
      "type": "studio.one.platform.ai.autoconfigure.config.AiAdapterProperties$ProviderType",
      "description": "Provider type for a named AI provider."
    },
    {
      "name": "studio.ai.providers.*.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable a named AI provider."
    },
    {
      "name": "studio.ai.providers.*.chat.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": false,
      "description": "Enable chat support for a named AI provider."
    },
    {
      "name": "studio.ai.providers.*.embedding.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": false,
      "description": "Enable embedding support for a named AI provider."
    },
    {
      "name": "studio.ai.providers.*.google-embedding.task-type",
      "type": "java.lang.String",
      "defaultValue": "RETRIEVAL_DOCUMENT",
      "description": "Google embedding task type fallback."
    },
    {
      "name": "studio.ai.rag.default-embedding-profile",
      "type": "java.lang.String",
      "description": "Default RAG embedding profile id."
    },
    {
      "name": "studio.ai.rag.embedding-profiles.*.provider",
      "type": "java.lang.String",
      "description": "Provider id for a RAG embedding profile."
    },
    {
      "name": "studio.ai.rag.embedding-profiles.*.model",
      "type": "java.lang.String",
      "description": "Embedding model for a RAG embedding profile."
    },
    {
      "name": "studio.ai.rag.embedding-profiles.*.dimension",
      "type": "java.lang.Integer",
      "description": "Embedding vector dimension for a RAG embedding profile."
    },
    {
      "name": "studio.ai.rag.embedding-profiles.*.supported-input-types",
      "type": "java.util.List<java.lang.String>",
      "defaultValue": [
        "TEXT",
        "TABLE_TEXT",
        "IMAGE_CAPTION",
        "OCR_TEXT"
      ],
      "description": "Supported input types for a RAG embedding profile."
    },
    {
      "name": "studio.ai.rag.embedding-profiles.*.metadata",
      "type": "java.util.Map<java.lang.String,java.lang.Object>",
      "description": "Additional metadata for a RAG embedding profile."
    },
    {
      "name": "studio.ai.rag.chunk-size",
      "type": "java.lang.Integer",
      "defaultValue": 500,
      "description": "Legacy fallback chunk size used when starter-chunking is absent."
    },
    {
      "name": "studio.ai.rag.chunk-overlap",
      "type": "java.lang.Integer",
      "defaultValue": 50,
      "description": "Legacy fallback chunk overlap used when starter-chunking is absent."
    },
    {
      "name": "studio.ai.rag.retrieval.vector-weight",
      "type": "java.lang.Double",
      "defaultValue": 0.7,
      "description": "Vector score weight for hybrid retrieval."
    },
    {
      "name": "studio.ai.rag.retrieval.lexical-weight",
      "type": "java.lang.Double",
      "defaultValue": 0.3,
      "description": "Lexical score weight for hybrid retrieval."
    },
    {
      "name": "studio.ai.rag.retrieval.keyword-fallback-enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable keyword-enriched fallback retrieval."
    },
    {
      "name": "studio.ai.rag.retrieval.semantic-fallback-enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable semantic fallback retrieval."
    },
    {
      "name": "studio.ai.rag.retrieval.min-relevance-score",
      "type": "java.lang.Double",
      "defaultValue": 0.15,
      "description": "Minimum relevance score for fallback success."
    },
    {
      "name": "studio.ai.rag.retrieval.query-expansion.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable query expansion for keyword fallback."
    },
    {
      "name": "studio.ai.rag.retrieval.query-expansion.max-keywords",
      "type": "java.lang.Integer",
      "defaultValue": 10,
      "description": "Maximum keywords used for query expansion."
    },
