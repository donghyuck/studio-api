    {
      "name": "studio.ai.rag.cache.ttl",
      "type": "java.time.Duration",
      "defaultValue": "10m",
      "description": "RAG cache time to live."
    },
    {
      "name": "studio.ai.rag.retry.max-attempts",
      "type": "java.lang.Integer",
      "defaultValue": 3,
      "description": "Maximum RAG retry attempts."
    },
    {
      "name": "studio.ai.rag.retry.wait-duration",
      "type": "java.time.Duration",
      "defaultValue": "2s",
      "description": "Wait duration between RAG retry attempts."
