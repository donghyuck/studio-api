    {
      "name": "studio.ai.rag.object-scope.default-list-limit",
      "type": "java.lang.Integer",
      "defaultValue": 20,
      "description": "Default object-scope list limit."
    },
    {
      "name": "studio.ai.rag.object-scope.max-list-limit",
      "type": "java.lang.Integer",
      "defaultValue": 200,
