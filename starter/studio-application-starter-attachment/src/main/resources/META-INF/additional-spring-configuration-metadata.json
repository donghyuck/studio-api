    {
      "name": "studio.features.attachment.thumbnail.base-dir",
      "type": "java.lang.String",
      "deprecation": {
        "level": "warning",
        "reason": "Attachment thumbnail moved to studio.attachment.thumbnail.*",
        "replacement": "studio.attachment.thumbnail.base-dir"
