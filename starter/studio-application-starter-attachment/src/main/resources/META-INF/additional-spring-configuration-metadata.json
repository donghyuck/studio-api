{
  "groups": [
    {
      "name": "studio.features.attachment",
      "description": "Attachment feature wiring properties."
    },
    {
      "name": "studio.attachment.storage",
      "description": "Attachment storage runtime properties."
    },
    {
      "name": "studio.attachment.thumbnail",
      "description": "Attachment thumbnail storage and attachment integration properties."
    },
    {
      "name": "studio.thumbnail",
      "description": "Platform thumbnail generation runtime properties."
    }
  ],
  "properties": [
    {
      "name": "studio.features.attachment.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": false,
      "description": "Enable the attachment feature."
    },
    {
      "name": "studio.features.attachment.web.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": false,
      "description": "Enable attachment web endpoints."
    },
    {
      "name": "studio.features.attachment.web.base-path",
      "type": "java.lang.String",
      "defaultValue": "/api/attachments",
      "description": "Base path for the attachment service API."
    },
    {
      "name": "studio.features.attachment.web.mgmt-base-path",
      "type": "java.lang.String",
      "defaultValue": "/api/mgmt/attachments",
      "description": "Base path for the attachment management API."
    },
    {
      "name": "studio.features.attachment.web.self-base",
      "type": "java.lang.String",
      "defaultValue": "/api/me/attachments",
      "description": "Base path for the authenticated user attachment API."
    },
    {
      "name": "studio.attachment.storage.type",
      "type": "java.lang.String",
      "defaultValue": "filesystem",
      "description": "Attachment binary storage type."
    },
    {
      "name": "studio.attachment.storage.base-dir",
      "type": "java.lang.String",
      "description": "Base directory for attachment files."
    },
    {
      "name": "studio.attachment.storage.ensure-dirs",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Create attachment storage directories on startup."
    },
    {
      "name": "studio.attachment.storage.cache-enabled",
      "type": "java.lang.Boolean",
      "defaultValue": false,
      "description": "Enable local cache for database-backed attachment storage."
    },
    {
      "name": "studio.attachment.thumbnail.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable attachment thumbnail generation."
    },
    {
      "name": "studio.attachment.thumbnail.base-dir",
      "type": "java.lang.String",
      "description": "Base directory for thumbnail files."
    },
    {
      "name": "studio.attachment.thumbnail.ensure-dirs",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Create attachment thumbnail directories on startup."
    },
    {
      "name": "studio.features.attachment.storage.type",
      "type": "java.lang.String",
      "deprecation": {
        "level": "warning",
