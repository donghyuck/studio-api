        "level": "warning",
        "reason": "Attachment storage moved to studio.attachment.storage.*",
        "replacement": "studio.attachment.storage.base-dir"
      }
    },
    {
      "name": "studio.features.attachment.storage.ensure-dirs",
      "type": "java.lang.Boolean",
      "deprecation": {
        "level": "warning",
        "reason": "Attachment storage moved to studio.attachment.storage.*",
        "replacement": "studio.attachment.storage.ensure-dirs"
      }
    },
    {
      "name": "studio.features.attachment.storage.cache-enabled",
      "type": "java.lang.Boolean",
      "deprecation": {
        "level": "warning",
        "reason": "Attachment storage moved to studio.attachment.storage.*",
        "replacement": "studio.attachment.storage.cache-enabled"
      }
